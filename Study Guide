ssh -T git@github.com       # test: should say "Hi username!"

### Daily commands
git status                    # what changed?
git add .                     # stage all changes
git add filename.py           # stage one file
git commit -m "feat: message" # save a snapshot
git push origin main          # send to GitHub
git pull origin main          # get latest from GitHub

### Branching — ALWAYS do this before making changes
git checkout -b feature/name  # create AND switch to new branch
git checkout main             # switch back
git branch -d branch-name     # safe delete (merged only)
git branch -D branch-name     # force delete

### Commit message prefixes
feat:   new feature
fix:    bug fix
chore:  maintenance, no logic change
docs:   documentation only
test:   adding or updating tests

### Virtual environment
python -m venv venv                  # create sandbox
source venv/Scripts/activate         # activate (Windows Git Bash)
source venv/bin/activate             # activate (Mac/Linux)
pip install -r requirements.txt      # install packages

